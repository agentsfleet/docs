      "source": "/fonts/CommitMono-Medium.woff2",
      "format": "woff2",
      "weight": 500
    },
    "body": {
      "family": "Instrument Sans",
      "source": "/fonts/InstrumentSans-Variable.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "styling": {
