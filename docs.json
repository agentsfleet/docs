{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "agentsfleet",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#14b8a6",
    "light": "#5eead4",
    "dark": "#5eead4"
  },
  "fonts": {
